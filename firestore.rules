rules_version = '2';

// ============================================================
// ENZOPIZZA HAJMÁSKÉR — Firestore Security Rules
//
// Deploy with the Firebase CLI:
//   firebase deploy --only firestore:rules
// (after copying this file's content into your project's
// firestore.rules, or pointing firebase.json at this file)
//
// Model:
//   - Anyone can READ menu/settings/review data (public site).
//   - Only signed-in users (the admin app) can WRITE.
//   - Tighten further with custom claims / an allow-list of
//     admin UIDs if you want defense-in-depth beyond the admin
//     app's own ALLOWED_EMAILS-style check (if you add one).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
